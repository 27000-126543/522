# .env 配置文件
# 复制此文件为 .env 并根据实际情况修改

# 应用配置
APP_NAME=智慧风电运维与故障预警调度系统
DEBUG=True

# 数据库配置 - 生产环境请使用PostgreSQL
# DATABASE_URL=postgresql+psycopg2://user:password@localhost/wind_power
DATABASE_URL=sqlite:///./wind_power.db

# JWT密钥 - 生产环境必须修改为强随机字符串
SECRET_KEY=change-this-secret-key-in-production-to-a-long-random-string-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 健康评分权重
HEALTH_SCORE_WEIGHT_VIBRATION=0.30
HEALTH_SCORE_WEIGHT_TEMPERATURE=0.25
HEALTH_SCORE_WEIGHT_POWER=0.20
HEALTH_SCORE_WEIGHT_NOISE=0.15
HEALTH_SCORE_WEIGHT_OTHER=0.10

# 预警阈值
WARNING_THRESHOLD_YELLOW=70.0
WARNING_THRESHOLD_ORANGE=50.0
WARNING_THRESHOLD_RED=30.0

# 工单超时配置
ORDER_AUTO_ASSIGN_TIMEOUT_MINUTES=30
ORDER_ESCALATE_TIMEOUT_MINUTES=120

# 顽固隐患判定天数
PERSISTENT_FAULT_DAYS=30
